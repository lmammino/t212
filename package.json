{
  "name": "t212-cli",
  "version": "0.1.1",
  "description": "Unofficial Trading 212 CLI for humans and AI agents.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lmammino/t212.git"
  },
  "bugs": {
    "url": "https://github.com/lmammino/t212/issues"
  },
  "homepage": "https://github.com/lmammino/t212#readme",
  "bin": {
    "t212": "dist/cli.js",
    "t212-cli": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "openapi",
    "README.md",
    "PUBLISHING.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "postbuild": "node --input-type=module -e \"import { chmodSync } from 'node:fs'; chmodSync('dist/cli.js', 0o755)\"",
    "generate:types": "openapi-typescript openapi/trading212.yaml -o src/generated/trading212.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm generate:types && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "audit": "pnpm audit --audit-level moderate",
    "prepack": "pnpm generate:types && pnpm build",
    "publish:dry-run": "npm publish --dry-run --access public"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@inquirer/prompts": "^8.4.2",
    "@napi-rs/keyring": "^1.2.0",
    "commander": "^14.0.3",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "lefthook": "^2.1.6",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
